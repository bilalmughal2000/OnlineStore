# ─────────────────────────────────────────────────────────────
# cPanel PRODUCTION environment
# Set these under each Node app's "Environment variables" in
# cPanel → Setup Node.js App. Replace store.pk / credentials with yours.
# (The admin is a static build — VITE_API_URL is baked in at build time.)
# ─────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Database (cPanel MySQL) ─────────────────────────────────
# Create the DB + user in cPanel → MySQL Databases (name is usually prefixed
# with your cPanel username, e.g. cpuser_store). `migrate deploy` uses these.
DATABASE_URL=mysql://cpuser_dbuser:PASSWORD@localhost:3306/cpuser_store?connection_limit=10&pool_timeout=20
DIRECT_DATABASE_URL=mysql://cpuser_dbuser:PASSWORD@localhost:3306/cpuser_store

# ── Auth (use long random strings) ─────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM
JWT_REFRESH_SECRET=REPLACE_WITH_LONG_RANDOM

# ── CORS: storefront + admin origins ───────────────────────
CORS_ORIGINS=https://store.pk,https://admin.store.pk

# ── Redis (OPTIONAL) — leave BLANK on shared cPanel (caching is skipped
#    cleanly). Set to an Upstash URL if you want caching. ──
REDIS_URL=

# ── Images (Cloudinary — recommended; keeps images off the cPanel disk) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (your cPanel mailbox SMTP) ───────────────────────
SMTP_HOST=mail.store.pk
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=orders@store.pk
SMTP_PASS=
EMAIL_FROM=Aabroo <orders@store.pk>

# ── Instant admin updates: API pings the storefront to revalidate ──
STOREFRONT_URL=https://store.pk
REVALIDATE_SECRET=REPLACE_WITH_SHARED_SECRET

# ── Storefront build/runtime (set for the storefront Node app) ─────
NEXT_PUBLIC_API_URL=https://api.store.pk/api

# ── Admin build (set BEFORE building the admin static bundle) ──────
VITE_API_URL=https://api.store.pk/api

# ── WhatsApp order notifications (OPTIONAL) ────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_ORDER=order_update
WHATSAPP_LANG=en
