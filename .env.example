# ─── Database ───────────────────────────────────────────────
# DATABASE_URL is used for runtime queries. connection_limit caps how many
# connections THIS process opens; pool_timeout is how long (s) a query waits
# for a free connection before erroring. Keep:
#   connection_limit × (PM2 instances) ≤ Postgres max_connections − headroom
DATABASE_URL="postgresql://store:store@localhost:5433/clothing_store?schema=public&connection_limit=10&pool_timeout=20"

# DIRECT_DATABASE_URL is a direct (non-pooled) connection used ONLY for
# migrations/introspection. Locally it's the same server. In production with a
# pooler, this must bypass the pooler (see examples below).
DIRECT_DATABASE_URL="postgresql://store:store@localhost:5433/clothing_store?schema=public"

# ── Production with a connection pooler (uncomment & adapt) ──
# PgBouncer (transaction mode) — note pgbouncer=true disables prepared statements:
#   DATABASE_URL="postgresql://user:pass@host:6432/db?pgbouncer=true&connection_limit=10&pool_timeout=20"
#   DIRECT_DATABASE_URL="postgresql://user:pass@host:5432/db"
# Supabase / Neon: use their pooler host for DATABASE_URL and the direct host for DIRECT_DATABASE_URL.

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6380"

# ─── API ────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── Auth (JWT) ─────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ─── Seed admin ─────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@store.pk"
SEED_ADMIN_PASSWORD="admin12345"

# ─── Storefront (Next.js) ───────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ─── Admin (Vite) ───────────────────────────────────────────
VITE_API_URL="http://localhost:4000/api"

# ─── Payments (Phase 4 — placeholders) ──────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
EASYPAISA_STORE_ID=""
EASYPAISA_HASH_KEY=""

# ─── Image uploads (Cloudinary) ─────────────────────────────
# If set, admin image uploads go to Cloudinary (CDN). If blank, dev falls back
# to storing uploads on local disk at apps/api/uploads (not for production).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Email / SMS (Phase 3+ — placeholders) ──────────────────
SENDGRID_API_KEY=""
EMAIL_FROM="orders@store.pk"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
