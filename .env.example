# ─── Database (MySQL) ───────────────────────────────────────
# DATABASE_URL is used for runtime queries. connection_limit caps how many
# connections THIS process opens; pool_timeout is how long (s) a query waits
# for a free connection before erroring. Keep:
#   connection_limit × (PM2 instances) ≤ MySQL max_connections − headroom
DATABASE_URL="mysql://root:root@localhost:3307/clothing_store?connection_limit=10&pool_timeout=20"

# DIRECT_DATABASE_URL is a direct (non-pooled) connection used ONLY for
# migrations/introspection. Locally it's the same server. Prisma `migrate dev`
# needs privileges to create a temporary shadow database — hence root locally.
DIRECT_DATABASE_URL="mysql://root:root@localhost:3307/clothing_store"

# ── Production (cPanel / managed MySQL) ─────────────────────
# Use your host's DB user + credentials. In production use `migrate deploy`
# (no shadow DB needed), so a limited DB user is fine:
#   DATABASE_URL="mysql://dbuser:pass@host:3306/dbname?connection_limit=10&pool_timeout=20"
#   DIRECT_DATABASE_URL="mysql://dbuser:pass@host:3306/dbname"

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6380"

# ─── API ────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── Auth (JWT) ─────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ─── Seed admin ─────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@store.pk"
SEED_ADMIN_PASSWORD="admin12345"

# ─── Storefront (Next.js) ───────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ─── Admin (Vite) ───────────────────────────────────────────
VITE_API_URL="http://localhost:4000/api"

# ─── Payments (Phase 4 — placeholders) ──────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
EASYPAISA_STORE_ID=""
EASYPAISA_HASH_KEY=""

# ─── Image uploads (Cloudinary) ─────────────────────────────
# If set, admin image uploads go to Cloudinary (CDN). If blank, dev falls back
# to storing uploads on local disk at apps/api/uploads (not for production).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Email (SMTP — e.g. your hosting provider's mailbox) ────
# Leave SMTP_HOST blank in dev to log emails to the console instead of sending.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"        # true for port 465, false for 587 (STARTTLS)
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Aabroo <orders@store.pk>"

# ─── WhatsApp Cloud API (official; optional) ────────────────
# When these are set, order notifications are also sent via WhatsApp using an
# approved template. Leave blank to disable (emails still send).
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_TEMPLATE_ORDER="order_update"   # name of your approved template
WHATSAPP_LANG="en"
