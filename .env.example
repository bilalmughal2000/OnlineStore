# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://store:store@localhost:5433/clothing_store?schema=public"

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6380"

# ─── API ────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── Auth (JWT) ─────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ─── Seed admin ─────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@store.pk"
SEED_ADMIN_PASSWORD="admin12345"

# ─── Storefront (Next.js) ───────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ─── Admin (Vite) ───────────────────────────────────────────
VITE_API_URL="http://localhost:4000/api"

# ─── Payments (Phase 4 — placeholders) ──────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
EASYPAISA_STORE_ID=""
EASYPAISA_HASH_KEY=""

# ─── Email / SMS (Phase 3+ — placeholders) ──────────────────
SENDGRID_API_KEY=""
EMAIL_FROM="orders@store.pk"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
